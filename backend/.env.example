# Server
PORT=5000
NODE_ENV=production

# Gemini AI — dapatkan dari https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key

# Supabase — dapatkan dari Project Settings > API
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Security — daftar origin yang diizinkan (pisah dengan koma)
CORS_ORIGINS=https://kopiai.vercel.app,http://localhost:5173

# Rate limiting — maks request per 15 menit per IP
RATE_LIMIT_MAX=100
